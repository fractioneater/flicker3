digraph ParseTree {
  rankdir=TB;
  node [fontname="Courier New"];
  n0 [label="program", shape=box, color=cornflowerblue, fontcolor=blue];
  n1 [label="printStmt", shape=box, color=cornflowerblue, fontcolor=blue];
  n0 -> n1;
  n2 [label="print", shape=ellipse, color=red, fontcolor=maroon];
  n1 -> n2;
  n3 [label="30", shape=ellipse, color=red, fontcolor=maroon];
  n1 -> n3;
  n4 [label="EOF", shape=ellipse, color=red, fontcolor=maroon];
  n0 -> n4;
}

