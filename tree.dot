digraph ParseTree {
  rankdir=TB;
  node [fontname="Courier New"];
  n0 [label="program", shape=box, color=blue, fontcolor=blue];
  n1 [label="codeItem", shape=box, color=blue, fontcolor=blue];
  n0 -> n1;
  n2 [label="expression", shape=box, color=blue, fontcolor=blue];
  n1 -> n2;
  n3 [label="three", shape=ellipse, color=green, fontcolor=darkgreen];
  n2 -> n3;
  n4 [label="EOF", shape=ellipse, color=green, fontcolor=darkgreen];
  n0 -> n4;
}

