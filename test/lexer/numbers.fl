# This is a line comment.
#: This is a
   block comment. #

# Numbers
val integer = 123
val hex = 0xABC
val bin = 0b1010
val float = 123.456
val exponent = 1.2E-3
val exponent2 = 1.2E+3
val exponent3 = 12E4

# Variables
var x: Int = 10
val y = "Hello"
val z: List of Int = [1, 2, 3]

# Using (Imports and Aliases)
using "std/math" for .
using "std/io" for `print` -> log, println
using MyInt = Int

# String interpolation
val s = "x is =(x)"
val s2 = "x + 1 is =(x + 1)"

# Control flow
if x > 0
  print "Positive"
elif x < 0
  print "Negative"
else
  print "Zero"

while x > 0
  x = x - 1
  if x == 5
    continue
  print x

for var i = 0; i < 10; i = i + 1
  print i

each item in [1, 2, 3]
  print item

each:loop value[index] in ["a", "b", "c"]
  print "=(index): =(value)"
  if (index > warningThreshold)
    break:loop

error "Uh-oh."

# When statement
when x
  1 do print "one"
  2
    print "two"
    print "still two"
  else do print "other"

# Functions
fun add(a: Int, b: Int) -> Int
  return a + b

fun short_add(a: Int, b: Int) = a + b

fun generic_func for T(item: T)
  print item

# Classes
class Person
  companion_namespace
    fun create() = Person()

  var name: String = ""
  fun greet()
    print "Hello, " + name

class Student is Person
  override fun greet()
    print "Hello, student " + name

# Expressions
val list = [1, 2, 3]
val map = ["a" -> 1, "b" -> 2]
val range = 1..10
val rangeLt = 1..<10
val nilCoalesce = x ?: 0
val power = 2 ** 10
val bitwise = (1 & 2) | (3 ^ 4)
val shift = 1 << 2 >> 1
val isCheck = x is Int
val inCheck = 1 in list
val ternary = 1 if x > 0 else false

# Lambdas
val lam1 = fun (a: Int, b: Int) = a + b
val lam2 = fun { (a: Int, b: Int) -> print a; print b; }
val lam3 = fun { a: Int, b: Int = a + b }

# Call with lambda
val result = [1, 2, 3].map {= it * 2 }

# Scoped identifiers
val something = Thing::thing
